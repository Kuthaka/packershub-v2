---
---
<section class="section contact-section" id="contact">
  <div class="container">
    <div class="section-header center animate-fadeUp">
      <div class="section-tag">Contact Us</div>
      <h2 class="heading-lg">We're Available <span class="text-gradient-gold">7 Days a Week</span></h2>
    </div>

    <div class="contact-grid">
      <div class="contact-card animate-fadeUp">
        <div class="contact-icon">📞</div>
        <div class="contact-title">Call / WhatsApp</div>
        <a href="tel:+917730912913" class="contact-link">+91 77309 12913</a>
        <div class="contact-meta">Mon–Sun: 7 AM – 9 PM</div>
      </div>

      <div class="contact-card animate-fadeUp" style="animation-delay: 0.1s;">
        <div class="contact-icon">✉️</div>
        <div class="contact-title">Email Us</div>
        <a href="mailto:info@packershub.in" class="contact-link">info@packershub.in</a>
        <div class="contact-meta">Reply within 2 hours</div>
      </div>

      <div class="contact-card animate-fadeUp" style="animation-delay: 0.2s;">
        <div class="contact-icon">📍</div>
        <div class="contact-title">Head Office</div>
        <p class="contact-text">BV Nagar, Nellore<br/>Andhra Pradesh – 524004</p>
      </div>

      <div class="contact-card contact-card-cta animate-fadeUp" style="animation-delay: 0.3s;">
        <div class="contact-icon">💬</div>
        <div class="contact-title" style="color:white;">WhatsApp Chat</div>
        <a href="https://wa.me/917730912913" class="btn btn-gold" style="margin-top:8px;">Open WhatsApp</a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section { background: var(--gray-50); padding: 100px 0; }
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 24px;
    max-width: 1000px;
    margin: 60px auto 0;
  }
  .contact-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 36px;
    text-align: center;
    border: 1px solid var(--gray-100);
    box-shadow: var(--shadow-card);
    transition: var(--transition);
  }
  .contact-card:hover { transform: translateY(-10px); border-color: var(--blue-200); }
  
  .contact-card-cta {
    background: var(--gradient-hero);
    border: none;
  }

  .contact-icon { font-size: 3rem; margin-bottom: 20px; }
  .contact-title {
    font-family: var(--font-ui);
    font-weight: 700;
    color: var(--gray-800);
    margin-bottom: 8px;
    font-size: 1.1rem;
  }
  .contact-link {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--blue-600);
    text-decoration: none;
    transition: 0.3s;
    display: block;
  }
  .contact-link:hover { color: var(--gold); }
  
  .contact-meta { font-size: 13px; color: var(--gray-400); margin-top: 8px; }
  .contact-text { font-size: 14px; color: var(--gray-600); line-height: 1.6; }

  @media (max-width: 768px) {
    .contact-section { padding: 60px 0; }
  }
</style>
