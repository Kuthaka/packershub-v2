</header>

<!-- MOBILE NAV -->
<nav class="mob-nav" id="mobNav">
    <div class="mob-nav-head">
        <div class="nav-logo"><div class="nav-logo-mark"></div>Packers<span>Hub</span></div>
        <button class="mob-close" id="mobClose">✕</button>
    </div>
    <div class="mob-links">
        <a href="#">Home</a>
        <a href="#about">About</a>
        <a href="#services">Services</a>
        <a href="#locations">75 Cities</a>
        <a href="#process">How It Works</a>
        <a href="#testimonials">Reviews</a>
        <a href="#blog">Blog</a>
        <a href="#contact">Contact</a>
    </div>
    <div class="mob-cta">
        <a class="btn btn-wa btn-lg" href="https://wa.me/917730912913?text=Hello! I need a moving quote.">💬 WhatsApp Us</a>
        <a class="btn btn-primary btn-lg" href="tel:+917730912913">📞 +91 77309 12913</a>
    </div>
</nav>

<style>
    #nav {
        position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
        height: var(--nav-h);
        transition: background var(--dur-base) var(--ease-out), box-shadow var(--dur-base) var(--ease-out);
    }
    #nav.scrolled {
        background: rgba(247,245,240,0.92);
        backdrop-filter: blur(24px) saturate(1.8);
        box-shadow: 0 1px 0 var(--c-border);
    }
    .nav-inner { height: var(--nav-h); display: flex; align-items: center; justify-content: space-between; gap: 24px; }
    .nav-logo { display: flex; align-items: center; gap: 10px; font-family: var(--f-display); font-size: 22px; font-weight: 900; color: var(--c-brand); letter-spacing: -.04em; }
    .nav-logo-mark { width: 38px; height: 38px; background: var(--c-brand); border-radius: 10px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
    .nav-logo-mark::before { content: '▶'; color: #fff; font-size: 14px; transform: rotate(-15deg); display: block; }
    .nav-logo span { color: var(--c-accent); }
    
    .nav-links { display: flex; align-items: center; gap: 4px; flex: 1; justify-content: center; }
    .nav-links a { padding: 7px 14px; border-radius: var(--r-full); font-size: 13.5px; font-weight: 600; color: var(--c-muted); transition: all var(--dur-fast); position: relative; }
    .nav-links a:hover { color: var(--c-brand); background: var(--c-border); }
    
    .nav-dd { position: relative; }
    .nav-dd-trigger { display: flex; align-items: center; gap: 4px; }
    .dd-arrow { font-size: 10px; opacity: .6; }
    .nav-dd-menu {
        position: absolute; top: calc(100% + 8px); left: 50%; transform: translateX(-50%) translateY(-6px);
        background: var(--c-surface); border-radius: var(--r-md); box-shadow: var(--shadow-lg); border: 1px solid var(--c-border);
        padding: 8px; min-width: 200px; opacity: 0; pointer-events: none; transition: opacity var(--dur-fast), transform var(--dur-base) var(--ease-out);
    }
    .nav-dd:hover .nav-dd-menu { opacity: 1; pointer-events: all; transform: translateX(-50%) translateY(0); }
    .nav-dd-menu a { display: block; padding: 9px 14px; border-radius: var(--r-sm); font-size: 13.5px; font-weight: 600; color: var(--c-ink); transition: background var(--dur-fast); }
    .nav-dd-menu a:hover { background: var(--c-bg); color: var(--c-accent); }
    
    .nav-cta { display: flex; align-items: center; gap: 10px; }
    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; }
    .hamburger span { display: block; width: 24px; height: 2px; background: var(--c-ink); border-radius: 2px; transition: var(--dur-base); }

    /* Mobile Nav */
    .mob-nav {
        position: fixed; inset: 0; z-index: 1100; background: var(--c-surface);
        transform: translateX(100%); transition: transform var(--dur-slow) var(--ease-out);
        padding: 28px; display: flex; flex-direction: column; overflow-y: auto;
    }
    .mob-nav.open { transform: translateX(0); }
    .mob-nav-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
    .mob-close { font-size: 28px; color: var(--c-ink); }
    .mob-links { display: flex; flex-direction: column; gap: 8px; flex: 1; }
    .mob-links a { display: block; padding: 14px 18px; border-radius: var(--r-md); font-size: 20px; font-weight: 700; color: var(--c-ink); transition: all var(--dur-fast); }
    .mob-links a:hover { background: var(--c-bg); color: var(--c-brand); }
    .mob-cta { display: flex; flex-direction: column; gap: 12px; margin-top: 32px; }

    @media(max-width:720px) {
        .nav-links { display: none; }
        .nav-cta .btn-outline { display: none; }
        .hamburger { display: flex; }
    }
</style>

<script>
    const nav = document.getElementById('nav');
    const ham = document.getElementById('hamTrigger');
    const close = document.getElementById('mobClose');
    const mobNav = document.getElementById('mobNav');

    window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
            nav.classList.add('scrolled');
        } else {
            nav.classList.remove('scrolled');
        }
    });

    ham?.addEventListener('click', () => mobNav.classList.add('open'));
    close?.addEventListener('click', () => mobNav.classList.remove('open'));
    
    document.querySelectorAll('.mob-links a').forEach(link => {
        link.addEventListener('click', () => mobNav.classList.remove('open'));
    });
</script>
