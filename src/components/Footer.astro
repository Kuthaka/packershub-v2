    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 60px; }
    
    .footer-logo { display: flex; align-items: center; gap: 10px; font-family: var(--f-display); font-size: 24px; font-weight: 900; color: #fff; margin-bottom: 18px; letter-spacing: -.04em; }
