---
---
<section class="section pricing" id="pricing">
  <div class="container">
    <div class="section-header center animate-fadeUp">
      <div class="section-tag">Pricing Plans</div>
      <h2 class="heading-lg">Transparent Pricing. <span class="text-gradient-gold">Zero Surprises.</span></h2>
      <p style="color:var(--gray-600); max-width:520px; margin:16px auto 0;">
        Choose the plan that fits your move. All plans include free packing materials, insurance, and our Damage-Free Guarantee.
      </p>
    </div>

    <div class="pricing-grid">
      <div class="pricing-card pricing-card-basic animate-fadeUp">
        <div class="pricing-icon">🏠</div>
        <div class="pricing-plan">Starter</div>
        <div class="pricing-price" style="color:var(--blue-800);">₹3,999<span style="font-size:1.2rem; font-weight:400; color:var(--gray-500);">/move</span></div>
        <p class="pricing-desc">Perfect for 1-2 BHK local moves within the same city.</p>
        <div class="pricing-features">
          <div class="pricing-feature"><span class="pricing-check">✓</span> Up to 20 km radius</div>
          <div class="pricing-feature"><span class="pricing-check">✓</span> Professional packing</div>
          <div class="pricing-feature"><span class="pricing-check">✓</span> Loading & unloading</div>
          <div class="pricing-feature"><span class="pricing-check">✓</span> Basic insurance cover</div>
          <div class="pricing-feature"><span class="pricing-check">✓</span> Same-day delivery</div>
        </div>
        <a href="tel:+917730912913" class="btn btn-blue" style="width:100%; justify-content:center;">Get This Plan</a>
      </div>

      <div class="pricing-card pricing-card-popular animate-fadeUp" style="animation-delay: 0.1s;">
        <div class="pricing-popular-badge">MOST POPULAR</div>
        <div class="pricing-icon">🚛</div>
        <div class="pricing-plan">Standard</div>
        <div class="pricing-price">₹7,999<span style="font-size:1.2rem; font-weight:400; color:rgba(255,255,255,0.6);">/move</span></div>
        <p class="pricing-desc">Ideal for 2-3 BHK intercity relocations across South India.</p>
        <div class="pricing-features">
          <div class="pricing-feature"><span class="pricing-check">✓</span> Intercity across 75 cities</div>
          <div class="pricing-feature"><span class="pricing-check">✓</span> Premium packing materials</div>
          <div class="pricing-feature"><span class="pricing-check">✓</span> GPS tracking included</div>
          <div class="pricing-feature"><span class="pricing-check">✓</span> ₹5 lakh insurance cover</div>
          <div class="pricing-feature"><span class="pricing-check">✓</span> Unpacking service</div>
          <div class="pricing-feature"><span class="pricing-check">✓</span> Dedicated move manager</div>
        </div>
        <a href="tel:+917730912913" class="btn btn-gold" style="width:100%; justify-content:center;">Get This Plan</a>
      </div>

      <div class="pricing-card pricing-card-premium animate-fadeUp" style="animation-delay: 0.2s;">
        <div class="pricing-icon">👑</div>
        <div class="pricing-plan">Premium</div>
        <div class="pricing-price">₹14,999<span style="font-size:1.2rem; font-weight:400; color:rgba(255,255,255,0.5);">/move</span></div>
        <p class="pricing-desc">Full-service luxury relocation for 3+ BHK homes and offices.</p>
        <div class="pricing-features">
          <div class="pricing-feature"><span class="pricing-check" style="background:rgba(201,148,58,0.3); color:var(--gold);">✓</span> Full packing & unpacking</div>
          <div class="pricing-feature"><span class="pricing-check" style="background:rgba(201,148,58,0.3); color:var(--gold);">✓</span> Air suspension trucks</div>
          <div class="pricing-feature"><span class="pricing-check" style="background:rgba(201,148,58,0.3); color:var(--gold);">✓</span> ₹20 lakh insurance</div>
          <div class="pricing-feature"><span class="pricing-check" style="background:rgba(201,148,58,0.3); color:var(--gold);">✓</span> Furniture assembly</div>
          <div class="pricing-feature"><span class="pricing-check" style="background:rgba(201,148,58,0.3); color:var(--gold);">✓</span> 30-day free storage</div>
          <div class="pricing-feature"><span class="pricing-check" style="background:rgba(201,148,58,0.3); color:var(--gold);">✓</span> Priority 24/7 support</div>
        </div>
        <a href="tel:+917730912913" class="btn btn-gold" style="width:100%; justify-content:center;">Get This Plan</a>
      </div>
    </div>

    <div style="text-align:center; margin-top:40px; padding:24px; background:var(--olive-pale); border-radius:var(--radius-lg); border:1px dashed var(--olive);" class="animate-fadeUp">
      <p style="color:var(--gray-700); font-family:var(--font-ui); font-size:15px;">
        🌿 All prices are starting estimates. Final pricing is transparent and fixed after free survey. 
        <strong style="color:var(--blue-700);">Call +91 77309 12913</strong> for custom corporate & bulk move pricing.
      </p>
    </div>
  </div>
</section>

<style>
  .pricing { background: var(--white); padding: 100px 0; }
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 60px;
  }
  .pricing-card {
    background: var(--white);
    border-radius: var(--radius-xl);
    padding: 48px 40px;
    border: 1px solid var(--gray-100);
    position: relative;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
  }
  .pricing-card:hover { transform: translateY(-10px); box-shadow: var(--shadow-card); }
  
  .pricing-card-popular {
    background: var(--gradient-hero);
    color: var(--white);
    border: none;
    transform: scale(1.05);
    z-index: 2;
  }
  .pricing-card-popular:hover { transform: scale(1.05) translateY(-10px); }
  .pricing-popular-badge {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--gradient-gold);
    color: var(--blue-900);
    padding: 8px 24px;
    border-radius: 100px;
    font-family: var(--font-ui);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .pricing-card-premium {
    background: var(--black);
    color: var(--white);
  }

  .pricing-icon { font-size: 3rem; margin-bottom: 24px; }
  .pricing-plan {
    font-family: var(--font-ui);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .pricing-price {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 900;
    margin-bottom: 16px;
    line-height: 1;
  }
  .pricing-desc { font-size: 15px; color: var(--gray-500); margin-bottom: 32px; line-height: 1.6; }
  .pricing-card-popular .pricing-desc, .pricing-card-premium .pricing-desc { color: rgba(255,255,255,0.6); }

  .pricing-features { flex: 1; display: flex; flex-direction: column; gap: 16px; margin-bottom: 40px; }
  .pricing-feature { display: flex; align-items: center; gap: 12px; font-size: 14px; font-weight: 500; }
  .pricing-check {
    width: 24px; height: 24px;
    background: rgba(30,111,232,0.1);
    color: var(--blue-500);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700;
  }
  .pricing-card-popular .pricing-check { background: rgba(255,255,255,0.15); color: var(--gold-light); }

  @media (max-width: 1100px) {
    .pricing-grid { grid-template-columns: 1fr; max-width: 450px; margin: 60px auto 0; }
    .pricing-card-popular { transform: none; }
    .pricing-card-popular:hover { transform: translateY(-10px); }
  }
</style>
