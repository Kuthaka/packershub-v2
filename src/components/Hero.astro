---
---
<section class="hero" id="home">
  <div class="hero-bg">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="orb orb-4"></div>
    <div class="hero-grid"></div>
  </div>

  <!-- Floating Info Boxes -->
  <div class="hero-float-box hero-float-box-1 animate-fadeUp" style="animation-delay: 0.6s;">
    <div class="float-icon" style="background:rgba(201,148,58,0.2);">⭐</div>
    <div class="float-text">
      <div class="float-num" style="color:#F5D98B;">4.9/5 Rating</div>
      <div class="float-label">3,800+ Verified Reviews</div>
    </div>
  </div>
  <div class="hero-float-box hero-float-box-2 animate-fadeUp" style="animation-delay: 0.8s;">
    <div class="float-icon" style="background:rgba(37,211,102,0.2);">✅</div>
    <div class="float-text">
      <div class="float-num" style="color:#86efac;">IBA Approved</div>
      <div class="float-label">Government Verified</div>
    </div>
  </div>
  <div class="hero-float-box hero-float-box-3 animate-fadeUp" style="animation-delay: 1s;">
    <div class="float-icon" style="background:rgba(232,83,122,0.2);">🛡</div>
    <div class="float-text">
      <div class="float-num" style="color:#FCA5A5;">100% Insured</div>
      <div class="float-label">Zero Damage Policy</div>
    </div>
  </div>

  <div class="container">
    <div class="hero-inner">
      <div class="hero-content">
        <div class="hero-pretitle animate-fadeUp">
          <span class="badge badge-gold">🏆 South India's #1 Packers & Movers</span>
          <div class="hero-rating">
            <span class="stars">★★★★★</span>
            <span class="rating-text">4.9 • 3,847 reviews</span>
          </div>
        </div>

        <h1 class="hero-title animate-fadeUp" style="animation-delay: 0.1s;">
          Move Smarter.<br/>
          <span class="line-gold">Move Safer.</span><br/>
          <!-- <span class="line-outline">Move with PackersHub.</span> -->
        </h1>

        <p class="hero-desc animate-fadeUp" style="animation-delay: 0.2s;">
          South India's most trusted relocation experts. We handle your precious belongings with military-grade care across 75 cities in Andhra Pradesh, Telangana, Tamil Nadu, Karnataka & Kerala — with zero hassle, 100% transparency, and a smile.
        </p>

        <div class="hero-actions animate-fadeUp" style="animation-delay: 0.3s;">
          <a href="tel:+917731074075" class="btn btn-gold" style="font-size:16px; padding:18px 36px;">
            📞 Get FREE Quote Now
          </a>
          <a href="https://wa.me/917731074075" class="btn btn-outline" style="font-size:16px; padding:18px 36px;">
            💬 WhatsApp Us
          </a>
        </div>

        <div class="hero-stats animate-fadeUp" style="animation-delay: 0.4s;">
          <div class="hero-stat">
            <div class="hero-stat-num">50,000<span>+</span></div>
            <div class="hero-stat-label">Happy Families</div>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <div class="hero-stat-num">75<span>+</span></div>
            <div class="hero-stat-label">Cities Served</div>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <div class="hero-stat-num">15<span>+</span></div>
            <div class="hero-stat-label">Years Experience</div>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <div class="hero-stat-num">0<span>%</span></div>
            <div class="hero-stat-label">Damage Rate</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    background: var(--gradient-hero);
    overflow: hidden;
    display: flex;
    align-items: center;
    padding-top: 80px;
  }

  /* 3D Animated Background */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.6;
  }
  .orb-1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(21,71,160,0.4), transparent 70%);
    top: -100px; right: -100px;
    animation: orb1 12s ease-in-out infinite;
  }
  .orb-2 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(201,148,58,0.2), transparent 70%);
    bottom: -100px; left: -100px;
    animation: orb2 15s ease-in-out infinite;
  }
  .orb-3 {
    width: 350px; height: 350px;
    background: radial-gradient(circle, rgba(232,83,122,0.15), transparent 70%);
    top: 50%; left: 40%;
    animation: orb1 18s ease-in-out infinite reverse;
  }
  .orb-4 {
    width: 250px; height: 250px;
    background: radial-gradient(circle, rgba(139,155,90,0.2), transparent 70%);
    top: 20%; left: 60%;
    animation: orb2 10s ease-in-out infinite;
  }

  /* Grid overlay */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  /* Floating boxes */
  .hero-float-box {
    position: absolute;
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    animation: float 6s ease-in-out infinite;
    z-index: 5;
  }
  .hero-float-box-1 {
    top: 18%;
    right: 8%;
    animation-delay: 0s;
  }
  .hero-float-box-2 {
    bottom: 28%;
    right: 12%;
    animation-delay: 2s;
  }
  .hero-float-box-3 {
    top: 35%;
    right: 3%;
    animation-delay: 4s;
  }
  .float-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }
  .float-text { color: rgba(255,255,255,0.9); }
  .float-num { font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; }
  .float-label { font-size: 11px; color: rgba(255,255,255,0.5); font-family: var(--font-ui); }

  .hero-inner {
    position: relative;
    z-index: 10;
    width: 100%;
  }
  .hero-content {
    max-width: 720px;
  }
  .hero-pretitle {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 28px;
  }
  .hero-rating {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(201,148,58,0.3);
    border-radius: 100px;
    padding: 6px 14px;
  }
  .stars { color: var(--gold); font-size: 14px; letter-spacing: 2px; }
  .rating-text { font-size: 13px; color: rgba(255,255,255,0.8); font-family: var(--font-ui); }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 900;
    line-height: 1.05;
    color: var(--white);
    margin-bottom: 24px;
  }
  .hero-title .line-gold {
    background: var(--gradient-gold);
    background-size: 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 3s linear infinite;
  }
  .hero-title .line-outline {
    -webkit-text-stroke: 2px rgba(255,255,255,0.4);
    -webkit-text-fill-color: transparent;
  }

  .hero-desc {
    font-size: 1.15rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.7;
    margin-bottom: 40px;
    max-width: 580px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 56px;
  }

  .hero-stats {
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
  }
  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .hero-stat-num {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 900;
    color: var(--white);
    line-height: 1;
  }
  .hero-stat-num span { color: var(--gold); }
  .hero-stat-label {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    font-family: var(--font-ui);
  }
  .hero-stat-divider {
    width: 1px;
    background: rgba(255,255,255,0.12);
    align-self: stretch;
  }

  @media (max-width: 1024px) {
    .hero-float-box { display: none; }
  }

  @media (max-width: 768px) {
    .hero { padding: 120px 0 60px; text-align: center; }
    .hero-content { margin: 0 auto; }
    .hero-pretitle { justify-content: center; }
    .hero-actions { justify-content: center; }
    .hero-stats { justify-content: center; gap: 24px; }
    .hero-stat-divider { display: none; }
    .hero-title { font-size: 2.8rem; }
  }
</style>
