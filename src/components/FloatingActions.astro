---
---
<div class="float-btns">
  <a href="https://wa.me/917731074075" class="float-btn float-btn-wa" target="_blank" rel="noopener">
    <span class="float-icon">💬</span>
    <span class="float-btn-tooltip">Chat on WhatsApp</span>
  </a>
  <a href="tel:+917731074075" class="float-btn float-btn-call">
    <span class="float-icon">📞</span>
    <span class="float-btn-tooltip">Call: +91 77310 74075</span>
  </a>
  <button id="btt" class="float-btn btt">
    <span class="float-icon">↑</span>
    <span class="float-btn-tooltip">Back to Top</span>
  </button>
</div>

<style>
  .float-btns {
    position: fixed;
    bottom: 30px;
    right: 30px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    z-index: 2000;
  }
  .float-btn {
    width: 60px; height: 60px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: var(--white);
    font-size: 24px;
    text-decoration: none;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    transition: var(--transition);
    position: relative;
    border: none;
    cursor: pointer;
  }
  .float-btn:hover { transform: scale(1.1) translateY(-5px); }
  .float-btn-wa { background: #25D366; }
  .float-btn-call { background: var(--blue-600); }
  .btt { background: var(--blue-900); border: 1px solid rgba(255,255,255,0.1); opacity: 0; pointer-events: none; }
  .btt.show { opacity: 1; pointer-events: all; }

  .float-btn-tooltip {
    position: absolute;
    right: calc(100% + 15px);
    top: 50%;
    transform: translateY(-50%) translateX(10px);
    background: var(--blue-900);
    color: var(--white);
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 13px;
    font-family: var(--font-ui);
    font-weight: 600;
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition: 0.3s;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
  }
  .float-btn:hover .float-btn-tooltip { opacity: 1; visibility: visible; transform: translateY(-50%) translateX(0); }

  @media (max-width: 768px) {
    .float-btns { bottom: 20px; right: 20px; }
    .float-btn { width: 50px; height: 50px; font-size: 20px; }
    .float-btn-tooltip { display: none; }
  }
</style>

<script>
  const btt = document.getElementById('btt');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 500) {
      btt?.classList.add('show');
    } else {
      btt?.classList.remove('show');
    }
  });
  btt?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
