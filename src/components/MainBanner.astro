---
---
<section class="main-banner">
  <div class="container">
    <div class="banner-wrapper animate-fadeUp">
      <img src="/images/main.jpg" alt="PackersHub Relocation Services" class="banner-img" />
      <div class="banner-overlay"></div>
    </div>
  </div>
</section>

<style>
  .main-banner {
    background: var(--gray-50);
    padding: 80px 0 0; /* Adding space above, but no space below to connect with QuoteForm */
  }
  .banner-wrapper {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    aspect-ratio: 21 / 9;
    border: 1px solid var(--gray-100);
  }
  .banner-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(10, 22, 40, 0.4));
  }

  @media (max-width: 768px) {
    .main-banner { padding: 40px 0 0; }
    .banner-wrapper { aspect-ratio: 16 / 9; }
  }
</style>
