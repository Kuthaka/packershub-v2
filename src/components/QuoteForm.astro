---
---
<section class="quote-section" id="quote">
  <div class="container">
    <div class="quote-card animate-fadeUp">
      <div class="quote-card-header">
        <div class="badge badge-gold" style="margin-bottom:16px;">⚡ Instant Quote — No Commitment</div>
        <h2 class="quote-card-title">Get Your FREE Moving Quote in 60 Seconds</h2>
        <p class="quote-card-sub">Tell us where you're moving — we'll give you the best price, guaranteed.</p>
      </div>
      <div class="quote-form">
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Moving From *</label>
            <select class="form-select" id="fromCity">
              <option value="">Select City</option>
              <optgroup label="Andhra Pradesh">
                <option>Nellore</option><option>Vijayawada</option><option>Visakhapatnam</option>
                <option>Guntur</option><option>Tirupati</option><option>Rajahmundry</option>
                <option>Kakinada</option><option>Kurnool</option><option>Eluru</option>
                <option>Ongole</option><option>Nandyal</option><option>Anantapur</option>
                <option>Kadapa</option><option>Chittoor</option><option>Srikakulam</option>
                <option>Vizianagaram</option><option>Bhimavaram</option><option>Machilipatnam</option>
                <option>Tenali</option><option>Hindupur</option>
              </optgroup>
              <optgroup label="Telangana">
                <option>Hyderabad</option><option>Warangal</option><option>Nizamabad</option>
                <option>Karimnagar</option><option>Khammam</option><option>Ramagundam</option>
                <option>Mahbubnagar</option><option>Nalgonda</option><option>Adilabad</option>
                <option>Suryapet</option><option>Miryalaguda</option><option>Siddipet</option>
                <option>Sangareddy</option><option>Mancherial</option>
              </optgroup>
              <optgroup label="Tamil Nadu">
                <option>Chennai</option><option>Coimbatore</option><option>Madurai</option>
                <option>Trichy</option><option>Salem</option><option>Tirunelveli</option>
                <option>Erode</option><option>Vellore</option><option>Thoothukudi</option>
                <option>Dindigul</option><option>Thanjavur</option><option>Ranipet</option>
                <option>Sivakasi</option><option>Karur</option><option>Udhagamandalam</option>
                <option>Hosur</option>
              </optgroup>
              <optgroup label="Karnataka">
                <option>Bengaluru</option><option>Mysuru</option><option>Hubballi</option>
                <option>Mangaluru</option><option>Belagavi</option><option>Kalaburagi</option>
                <option>Ballari</option><option>Vijayapura</option><option>Shimoga</option>
                <option>Tumkur</option><option>Davangere</option><option>Raichur</option>
                <option>Bidar</option><option>Hassan</option><option>Udupi</option>
              </optgroup>
              <optgroup label="Kerala">
                <option>Thiruvananthapuram</option><option>Kochi</option><option>Kozhikode</option>
                <option>Thrissur</option><option>Kollam</option><option>Palakkad</option>
                <option>Alappuzha</option><option>Kannur</option><option>Kottayam</option>
                <option>Malappuram</option>
              </optgroup>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Moving Floor From *</label>
            <select class="form-select">
              <option>Ground Floor</option>
              <option>1st Floor</option>
              <option>2nd Floor</option>
              <option>3rd Floor</option>
              <option>4th Floor</option>
              <option>5th+ Floor</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Moving To *</label>
            <select class="form-select" id="toCity">
              <option value="">Select City</option>
              <optgroup label="Andhra Pradesh">
                <option>Nellore</option><option>Vijayawada</option><option>Visakhapatnam</option>
                <option>Guntur</option><option>Tirupati</option><option>Rajahmundry</option>
              </optgroup>
              <optgroup label="Telangana">
                <option>Hyderabad</option><option>Warangal</option><option>Nizamabad</option>
              </optgroup>
              <optgroup label="Tamil Nadu">
                <option>Chennai</option><option>Coimbatore</option><option>Madurai</option>
              </optgroup>
              <optgroup label="Karnataka">
                <option>Bengaluru</option><option>Mysuru</option><option>Hubballi</option>
              </optgroup>
              <optgroup label="Kerala">
                <option>Thiruvananthapuram</option><option>Kochi</option><option>Kozhikode</option>
              </optgroup>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Moving Floor To *</label>
            <select class="form-select">
              <option>Ground Floor</option>
              <option>1st Floor</option>
              <option>2nd Floor</option>
              <option>3rd Floor</option>
              <option>4th Floor</option>
              <option>5th+ Floor</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Move Type *</label>
            <select class="form-select">
              <option value="">Select Type</option>
              <option>Household Shifting</option>
              <option>Office Relocation</option>
              <option>Car Transport</option>
              <option>Bike Transport</option>
              <option>Warehouse Storage</option>
              <option>International Move</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Move Date *</label>
            <input type="date" class="form-input" />
          </div>
          <div class="form-group">
            <label class="form-label">Your Name *</label>
            <input type="text" class="form-input" placeholder="Enter your full name" />
          </div>
          <div class="form-group">
            <label class="form-label">Phone Number *</label>
            <input type="tel" class="form-input" placeholder="+91 XXXXX XXXXX" />
          </div>
        </div>
        <button class="btn btn-gold form-submit" id="submitQuote">
          🚀 Get My FREE Quote — Instant Response!
        </button>
        <p style="text-align:center; margin-top:16px; font-size:13px; color:var(--gray-400);">
          🔒 100% Safe & Confidential · No spam · Free, no obligation
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .quote-section {
    background: var(--gray-50);
    padding: 60px 0 100px;
  }
  .quote-card {
    background: var(--white);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    border: 1px solid var(--gray-100);
  }
  .quote-card-header {
    background: var(--gradient-hero);
    padding: 40px 48px;
    position: relative;
    overflow: hidden;
  }
  .quote-card-header::after {
    content: '📦';
    position: absolute;
    right: 40px;
    bottom: -20px;
    font-size: 120px;
    opacity: 0.08;
  }
  .quote-card-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 8px;
  }
  .quote-card-sub { color: rgba(255,255,255,0.65); font-size: 14px; }

  .quote-form {
    padding: 40px 48px;
  }
  .form-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 24px;
  }
  .form-group { display: flex; flex-direction: column; gap: 8px; }
  .form-label {
    font-family: var(--font-ui);
    font-size: 13px;
    font-weight: 600;
    color: var(--gray-600);
    letter-spacing: 0.05em;
  }
  .form-input, .form-select {
    width: 100%;
    padding: 14px 18px;
    border: 1.5px solid var(--gray-200);
    border-radius: 12px;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--gray-800);
    background: var(--white);
    transition: var(--transition);
    outline: none;
    appearance: none;
  }
  .form-input:focus, .form-select:focus {
    border-color: var(--blue-500);
    box-shadow: 0 0 0 4px rgba(30,111,232,0.1);
  }
  .form-input::placeholder { color: var(--gray-400); }

  .form-submit { width: 100%; padding: 18px; font-size: 16px; border-radius: 14px; cursor: pointer; border: none; }

  @media (max-width: 768px) {
    .quote-form, .quote-card-header { padding: 32px 24px; }
    .quote-card-title { font-size: 1.5rem; }
  }
</style>

<script>
  const submitBtn = document.getElementById('submitQuote');
  submitBtn?.addEventListener('click', () => {
    alert('Thank you! Our expert will call you within 15 minutes with your custom quote.');
  });
</script>
