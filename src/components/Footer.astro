    .footer-desc { font-size: 14px; line-height: 1.7; color: rgba(255,255,255,.5); margin-bottom: 24px; max-width: 300px; }
    
    .footer-socials { display: flex; gap: 8px; }
    .social-btn {
        width: 38px; height: 38px; border-radius: 50%;
        background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12);
        display: grid; place-items: center; font-size: 15px; color: rgba(255,255,255,.7);
        transition: all var(--dur-fast);
    }
    .social-btn:hover { background: rgba(255,255,255,.18); color: #fff; transform: translateY(-3px); }
    
    .footer-col h4 { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .12em; color: #fff; margin-bottom: 20px; font-family: var(--f-mono); }
    .footer-links { display: flex; flex-direction: column; gap: 10px; }
    .footer-links a { font-size: 14px; color: rgba(255,255,255,.5); transition: all var(--dur-fast); }
    .footer-links a:hover { color: rgba(255,255,255,.9); padding-left: 4px; }
    
    .footer-bottom { border-top: 1px solid rgba(255,255,255,.08); padding: 28px 0; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
    .footer-bottom p { font-size: 13px; color: rgba(255,255,255,.35); }

    @media(max-width:1100px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 40px; } }
    @media(max-width:720px) { .footer-grid { grid-template-columns: 1fr; } .footer-bottom { justify-content: center; text-align: center; } }
</style>
