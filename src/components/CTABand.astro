<div class="cta-band animate-fadeUp">
  <div class="container">
    <div class="cta-band-inner">
      <div class="cta-band-text">
        <h2 class="cta-band-title">Ready to Move? <br/>Let's Make It Happen.</h2>
        <p class="cta-band-sub">Join 50,000+ families who moved smart with PackersHub. Your stress-free move starts with one call.</p>
      </div>
      <div class="cta-band-actions">
        <a href="tel:+917731074075" class="btn" style="background:var(--blue-900); color:white; font-size:16px; padding:18px 36px;">
          📞 Call +91 77310 74075
        </a>
        <a href="https://wa.me/917731074075" class="btn" style="background:rgba(10,22,40,0.15); color:var(--blue-900); border:2px solid rgba(10,22,40,0.3); font-size:16px; padding:18px 36px;">
          💬 WhatsApp Us
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .cta-band {
    background: var(--gradient-gold);
    padding: 60px 0;
    position: relative;
    z-index: 10;
  }
  .cta-band-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
  }
  .cta-band-title {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 900;
    color: var(--blue-900);
    line-height: 1.1;
    margin-bottom: 12px;
  }
  .cta-band-sub {
    font-size: 16px;
    color: rgba(10,22,40,0.7);
    max-width: 500px;
  }
  .cta-band-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  @media (max-width: 1024px) {
    .cta-band-inner { flex-direction: column; text-align: center; }
    .cta-band-actions { justify-content: center; }
  }
</style>
