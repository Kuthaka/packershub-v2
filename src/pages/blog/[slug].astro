---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FloatingActions from '../../components/FloatingActions.astro';
import { getBlogPosts, getBlogPostBySlug, urlFor } from '../../sanity/api';
import { PortableText } from 'astro-portabletext';

export async function getStaticPaths() {
	const posts = await getBlogPosts();
	return posts.map(post => ({
		params: { slug: post.slug.current }
	}));
}

const { slug } = Astro.params;
const post = await getBlogPostBySlug(slug);

if (!post) return Astro.redirect('/404');

const publishedDate = new Date(post.publishedAt).toLocaleDateString('en-IN', {
	month: 'long',
	day: 'numeric',
	year: 'numeric'
});
---

<Layout title={`${post.title} | PackersHub Blog`}>
	<Header />
	<main>
		<!-- Post Header -->
		<article class="post-container">
			<header class="post-header">
				<div class="container narrow">
					<div class="post-header-content animate-fadeUp">
						<div class="post-meta-top">
							{post.categories?.map(cat => (
								<span class="category-badge">{cat.title}</span>
							))}
							<span class="dot">•</span>
							<span class="read-time">{post.readTime} min read</span>
						</div>
						<h1 class="post-title">{post.title}</h1>
						<p class="post-excerpt">{post.excerpt}</p>
						
						<div class="post-author-box">
							<img src={post.author.image ? urlFor(post.author.image).url() : 'https://placehold.co/100x100/0A1628/F5D98B?text=PH'} alt={post.author.name} />
							<div class="author-details">
								<div class="name">{post.author.name}</div>
								<div class="role">{post.author.role}</div>
							</div>
							<div class="divider"></div>
							<div class="date-box">
								<div class="label">Published</div>
								<div class="val">{publishedDate}</div>
							</div>
						</div>
					</div>
				</div>
			</header>

			<!-- Featured Image -->
			<div class="container">
				<div class="main-image animate-fadeUp" style="animation-delay: 0.2s;">
					<img src={post.mainImage ? urlFor(post.mainImage).url() : 'https://placehold.co/1200x800/0A1628/F5D98B?text=PackersHub'} alt={post.title} />
				</div>
			</div>

			<!-- Post Body -->
			<div class="container narrow">
				<div class="post-body">
					{post.body && <PortableText value={post.body} />}
				</div>

				<!-- Share & Tags -->
				<footer class="post-footer animate-fadeUp">
					<div class="tags">
						{post.categories?.map(cat => (
							<span class="tag">#{cat.title.toLowerCase().replace(' ', '')}</span>
						))}
					</div>
					<div class="share-box">
						<span>Share this article:</span>
						<div class="share-links">
							<a href={`https://twitter.com/intent/tweet?text=${post.title}&url=${Astro.url}`} target="_blank">𝕏</a>
							<a href={`https://www.linkedin.com/sharing/share-offsite/?url=${Astro.url}`} target="_blank">in</a>
							<a href={`https://wa.me/?text=${post.title}%20${Astro.url}`} target="_blank">💬</a>
						</div>
					</div>
				</footer>

				<!-- Author Bio -->
				<section class="author-bio-card">
					<img src={post.author.image ? urlFor(post.author.image).url() : 'https://placehold.co/100x100/0A1628/F5D98B?text=PH'} alt={post.author.name} />
					<div class="bio-content">
						<h3>About {post.author.name}</h3>
						<div class="bio-text">
							{post.author.bio && <PortableText value={post.author.bio} />}
						</div>
					</div>
				</section>
			</div>

			<!-- Related Posts -->
			{post.relatedPosts && post.relatedPosts.length > 0 && (
				<section class="related-posts">
					<div class="container">
						<h2 class="heading-lg text-center" style="margin-bottom: 50px;">You Might Also <span class="text-gradient-gold">Like</span></h2>
						<div class="related-grid">
							{post.relatedPosts.map(rel => (
								<a href={`/blog/${rel.slug.current}`} class="related-card">
									<img src={rel.mainImage ? urlFor(rel.mainImage).url() : 'https://placehold.co/600x400/0A1628/F5D98B?text=PackersHub'} alt={rel.title} />
									<div class="rel-content">
										<h3>{rel.title}</h3>
										<span class="arrow">Read More →</span>
									</div>
								</a>
							))}
						</div>
					</div>
				</section>
			)}
		</article>
	</main>
	<Footer />
	<FloatingActions />
</Layout>

<style>
	.post-container { padding: 120px 0 100px; }
	.container.narrow { max-width: 860px; }
	
	.post-header { text-align: center; margin-bottom: 60px; }
	.post-meta-top { display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 24px; }
	.category-badge { background: var(--blue-50); color: var(--blue-600); padding: 6px 14px; border-radius: 100px; font-weight: 700; font-family: var(--font-ui); font-size: 12px; text-transform: uppercase; }
	.post-title { font-family: var(--font-display); font-size: clamp(2.2rem, 5vw, 3.8rem); line-height: 1.1; color: var(--blue-900); margin-bottom: 24px; }
	.post-excerpt { font-size: 1.25rem; color: var(--gray-800); line-height: 1.6; max-width: 700px; margin: 0 auto 40px; }
	
	.post-author-box { display: flex; align-items: center; justify-content: center; gap: 24px; background: var(--gray-50); padding: 16px 32px; border-radius: 100px; width: fit-content; margin: 0 auto; border: 1px solid var(--gray-100); }
	.post-author-box img { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; }
	.author-details { text-align: left; }
	.author-details .name { font-weight: 700; color: var(--blue-900); font-size: 15px; }
	.author-details .role { font-size: 12px; color: var(--gray-400); }
	.divider { width: 1px; height: 30px; background: var(--gray-200); }
	.date-box { text-align: left; }
	.date-box .label { font-size: 10px; text-transform: uppercase; color: var(--gray-400); font-weight: 700; }
	.date-box .val { font-size: 14px; color: var(--blue-900); font-weight: 600; }

	.main-image { margin-bottom: 80px; border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-card); height: 500px; }
	.main-image img { width: 100%; height: 100%; object-fit: cover; }

	.post-body { font-size: 1.15rem; line-height: 1.8; color: #000000 !important; }
	.post-body :global(*) { color: #000000 !important; }
	.post-body :global(h2) { font-family: var(--font-display); font-size: 2rem; color: var(--blue-900); margin: 60px 0 24px; }
	.post-body :global(h3) { font-family: var(--font-display); font-size: 1.5rem; color: var(--blue-900); margin: 40px 0 20px; }
	.post-body :global(p) { margin-bottom: 24px; }
	.post-body :global(ul) { margin-bottom: 32px; padding-left: 20px; list-style: disc; }
	.post-body :global(li) { margin-bottom: 12px; }
	.post-body :global(strong) { color: var(--blue-900); font-weight: 700; }

	.post-footer { margin-top: 60px; padding-top: 40px; border-top: 1px solid var(--gray-100); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 24px; }
	.tags { display: flex; gap: 10px; }
	.tag { color: var(--blue-500); font-size: 14px; font-weight: 600; }
	.share-box { display: flex; align-items: center; gap: 16px; font-size: 14px; color: var(--gray-600); }
	.share-links { display: flex; gap: 10px; }
	.share-links a { width: 36px; height: 36px; border-radius: 50%; background: var(--gray-50); display: flex; align-items: center; justify-content: center; color: var(--blue-900); font-weight: 700; transition: var(--transition); border: 1px solid var(--gray-100); }
	.share-links a:hover { background: var(--blue-600); color: var(--white); transform: translateY(-3px); }

	.author-bio-card { margin-top: 80px; background: var(--gray-50); padding: 40px; border-radius: var(--radius-md); display: flex; gap: 32px; border: 1px solid var(--gray-100); }
	.author-bio-card img { width: 100px; height: 100px; border-radius: 24px; object-fit: cover; flex-shrink: 0; }
	.bio-content h3 { font-family: var(--font-display); font-size: 1.5rem; color: var(--blue-900); margin-bottom: 12px; }
	.bio-text { font-size: 15px; color: var(--gray-800); line-height: 1.6; }

	.related-posts { padding: 100px 0; background: var(--gray-50); margin-top: 100px; }
	.related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
	.related-card { background: var(--white); border-radius: var(--radius-md); overflow: hidden; border: 1px solid var(--gray-100); transition: var(--transition); }
	.related-card:hover { transform: translateY(-8px); box-shadow: var(--shadow-card); }
	.related-card img { width: 100%; height: 180px; object-fit: cover; }
	.rel-content { padding: 20px; }
	.rel-content h3 { font-size: 1.1rem; color: var(--blue-900); margin-bottom: 12px; line-height: 1.4; }
	.rel-content .arrow { color: var(--blue-600); font-size: 13px; font-weight: 700; }

	@media (max-width: 768px) {
		.post-container { padding: 100px 0 60px; }
		.post-author-box { flex-direction: column; padding: 24px; border-radius: 24px; gap: 12px; }
		.divider { width: 40px; height: 1px; }
		.author-details, .date-box { text-align: center; }
		.main-image { height: 300px; margin-bottom: 40px; }
		.author-bio-card { flex-direction: column; text-align: center; align-items: center; padding: 30px 20px; }
		.related-grid { grid-template-columns: 1fr; }
	}
</style>
